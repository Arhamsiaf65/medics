# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to Git - it's in .gitignore

# MongoDB Atlas Connection
MONGODB_URI="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/myDatabase?retryWrites=true&w=majority"

# JWT Secret (generate a new random string for production)
JWT_SECRET="your-super-secret-jwt-key-here"

# Email Configuration
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-specific-password"

# Redis/Upstash Connection
REDIS_URL="rediss://default:password@hostname.upstash.io:6379"

# Frontend URL (for CORS - update after deployment)
FRONTEND_URL="http://localhost:5173"

# Server Port (optional - Railway assigns automatically)
PORT=5000

# Node Environment
NODE_ENV="development"
